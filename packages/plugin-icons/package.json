{
	"name": "@pikacss/plugin-icons",
	"type": "module",
	"version": "0.0.47",
	"author": "DevilTea <ch19980814@gmail.com>",
	"license": "MIT",
	"homepage": "https://pikacss.com",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/pikacss/pikacss.githiub.io.git",
		"directory": "packages/plugin-icons"
	},
	"bugs": {
		"url": "https://github.com/pikacss/pikacss/issues"
	},
	"keywords": [
		"pikacss",
		"atomic-css",
		"css-in-js",
		"atomic-css-in-js-engine",
		"pikacss-plugin",
		"icons"
	],
	"sideEffects": false,
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			}
		}
	},
	"module": "dist/index.mjs",
	"types": "dist/index.d.mts",
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"dist"
	],
	"engines": {
		"node": ">=22"
	},
	"scripts": {
		"build": "tsdown",
		"build:watch": "tsdown --watch",
		"typecheck": "pnpm typecheck:package && pnpm typecheck:test",
		"typecheck:package": "tsc --project ./tsconfig.package.json --noEmit",
		"typecheck:test": "tsc --project ./tsconfig.tests.json --noEmit",
		"test": "vitest run --config ./vitest.config.ts",
		"test:watch": "vitest --config ./vitest.config.ts"
	},
	"peerDependencies": {
		"@pikacss/core": "workspace:*"
	},
	"dependencies": {
		"@iconify/utils": "catalog:",
		"ofetch": "catalog:"
	},
	"devDependencies": {
		"@pikacss/core": "workspace:*"
	}
}
