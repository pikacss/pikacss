{
	"name": "pikacss-monorepo",
	"type": "module",
	"version": "0.0.57",
	"private": true,
	"packageManager": "pnpm@10.34.4",
	"description": "The instant on-demand atomic css-in-js engine.",
	"author": "DevilTea <ch19980814@gmail.com>",
	"license": "MIT",
	"keywords": [
		"pikacss",
		"atomic-css",
		"css-in-js",
		"atomic-css-in-js-engine"
	],
	"engines": {
		"node": ">=22"
	},
	"scripts": {
		"build": "pnpm -r --filter='./packages/*' build",
		"generate:css-data": "tsx ./scripts/css-data/generate.ts",
		"generate:core:csstype": "pnpm generate:css-data && tsx ./scripts/css-data/generate-csstype.ts",
		"generate:core:property-effects": "pnpm generate:css-data && tsx ./scripts/css-data/generate-property-effects.ts",
		"generate:core:css": "pnpm generate:css-data && tsx ./scripts/css-data/generate-csstype.ts && tsx ./scripts/css-data/generate-property-effects.ts",
		"maintain-docs:analyze": "tsx ./scripts/maintain-docs/analyze.ts",
		"maintain-docs:gen-api": "tsx ./scripts/maintain-docs/gen-api-docs.ts",
		"maintain-jsdocs:lint": "tsx ./scripts/maintain-jsdocs/lint.ts",
		"maintain-jsdocs:scaffold": "tsx ./scripts/maintain-jsdocs/scaffold.ts",
		"maintain-i18n:status": "tsx ./scripts/maintain-i18n/status.ts",
		"maintain-i18n:lint": "tsx ./scripts/maintain-i18n/lint.ts",
		"update:browsers": "pnpm up -r @mdn/browser-compat-data @webref/css mdn-data web-features",
		"newpkg": "tsx ./scripts/newpkg.ts",
		"newplugin": "tsx ./scripts/newplugin.ts",
		"publint": "pnpm -r --filter='./packages/*' exec publint",
		"attw": "node scripts/check-attw.mjs",
		"publish:packages": "pnpm -r --filter='./packages/*' publish --no-git-checks",
		"docs:dev": "pnpm -r --filter=@pikacss/docs run dev",
		"repopack": "tsx ./scripts/repopack.ts",
		"test:css-data": "vitest --config ./scripts/css-data/vitest.config.ts run && pnpm generate:core:css && pnpm --filter @pikacss/core typecheck",
		"type-bench": "tsx ./scripts/type-bench/index.ts",
		"docs:build": "pnpm -r --filter=@pikacss/docs run build",
		"docs:preview": "pnpm -r --filter=@pikacss/docs run preview",
		"playground:dev": "pnpm -r --filter=@pikacss/playground run dev",
		"playground:build": "pnpm -r --filter=@pikacss/playground run build",
		"playground:preview": "pnpm -r --filter=@pikacss/playground run preview",
		"typecheck": "pnpm -r typecheck",
		"test": "pnpm test:css-data && pnpm -r --filter='./packages/*' run test",
		"test:e2e": "node packages/unplugin/e2e/vite-build.mjs",
		"lint": "eslint --max-warnings=0 .",
		"lint:fix": "eslint --fix .",
		"prepare": "simple-git-hooks"
	},
	"devDependencies": {
		"@arethetypeswrong/cli": "catalog:",
		"@clack/prompts": "catalog:",
		"@deviltea/eslint-config": "catalog:",
		"@deviltea/tsconfig": "catalog:",
		"@mdn/browser-compat-data": "catalog:",
		"@pikacss/core": "workspace:*",
		"@pikacss/eslint-config": "workspace:*",
		"@types/node": "catalog:",
		"@vitest/coverage-v8": "catalog:",
		"@webref/css": "catalog:",
		"bumpp": "catalog:",
		"changelogithub": "catalog:",
		"eslint": "catalog:",
		"globby": "catalog:",
		"gray-matter": "catalog:",
		"happy-dom": "catalog:",
		"lint-staged": "catalog:",
		"local-pkg": "catalog:",
		"mdn-data": "catalog:",
		"pathe": "catalog:",
		"pkg-pr-new": "catalog:",
		"publint": "catalog:",
		"repomix": "catalog:",
		"simple-git-hooks": "catalog:",
		"tsdown": "catalog:",
		"tsx": "catalog:",
		"typescript": "catalog:",
		"vitest": "catalog:",
		"web-features": "catalog:",
		"zx": "catalog:"
	},
	"simple-git-hooks": {
		"pre-commit": "pnpm lint-staged"
	},
	"lint-staged": {
		"*": "eslint --fix --config eslint.config.mjs --no-warn-ignored"
	}
}
