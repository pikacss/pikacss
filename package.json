{
	"name": "pikacss-monorepo",
	"type": "module",
	"version": "0.0.49",
	"private": true,
	"packageManager": "pnpm@10.30.2",
	"description": "The instant on-demand atomic css-in-js engine.",
	"author": "DevilTea <ch19980814@gmail.com>",
	"license": "MIT",
	"keywords": [
		"pikacss",
		"atomic-css",
		"css-in-js",
		"atomic-css-in-js-engine"
	],
	"engines": {
		"node": ">=22"
	},
	"scripts": {
		"build": "pnpm -r --filter='./packages/*' build",
		"maintain-docs:analyze": "tsx ./scripts/maintain-docs/analyze.ts",
		"maintain-docs:gen-api": "tsx ./scripts/maintain-docs/gen-api-docs.ts",
		"maintain-jsdocs:lint": "tsx ./scripts/maintain-jsdocs/lint.ts",
		"maintain-jsdocs:scaffold": "tsx ./scripts/maintain-jsdocs/scaffold.ts",
		"newpkg": "tsx ./scripts/newpkg.ts",
		"newplugin": "tsx ./scripts/newplugin.ts",
		"publint": "pnpm -r --filter='./packages/*' exec publint",
		"publish:packages": "pnpm -r --filter='./packages/*' publish --no-git-checks",
		"docs:dev": "pnpm -r --filter=@pikacss/docs run dev",
		"repopack": "tsx ./scripts/repopack.ts",
		"type-bench": "tsx ./scripts/type-bench/index.ts",
		"docs:build": "pnpm -r --filter=@pikacss/docs run build",
		"docs:preview": "pnpm -r --filter=@pikacss/docs run preview",
		"typecheck": "pnpm -r typecheck",
		"test": "pnpm -r --filter='./packages/*' run test",
		"lint": "eslint --fix .",
		"prepare": "simple-git-hooks"
	},
	"devDependencies": {
		"@clack/prompts": "catalog:",
		"@deviltea/eslint-config": "catalog:",
		"@deviltea/tsconfig": "catalog:",
		"@mdn/browser-compat-data": "catalog:",
		"@pikacss/core": "workspace:*",
		"@pikacss/eslint-config": "workspace:*",
		"@types/node": "catalog:",
		"@vitest/coverage-v8": "catalog:",
		"eslint": "catalog:",
		"globby": "catalog:",
		"gray-matter": "catalog:",
		"happy-dom": "catalog:",
		"lint-staged": "catalog:",
		"magic-string": "catalog:",
		"mdn-data": "catalog:",
		"oxc-parser": "catalog:",
		"pathe": "catalog:",
		"pkg-pr-new": "catalog:",
		"pkg-size": "catalog:",
		"publint": "catalog:",
		"repomix": "catalog:",
		"simple-git-hooks": "catalog:",
		"tsdown": "catalog:",
		"tsx": "catalog:",
		"typescript": "catalog:",
		"vitest": "catalog:",
		"vue-tsc": "catalog:",
		"web-features": "catalog:",
		"zx": "catalog:"
	},
	"simple-git-hooks": {
		"pre-commit": "pnpm lint-staged"
	},
	"lint-staged": {
		"*": "eslint --fix"
	}
}
